{
  "name": "dnd-dice-roller",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "infra"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
