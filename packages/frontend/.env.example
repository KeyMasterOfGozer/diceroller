# Copy to .env.local and fill in values from `cdk deploy` outputs
VITE_REGION=us-east-1
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# AWS profile to use for deployments (deploy.mjs reads this automatically).
# CDK also respects AWS_PROFILE natively — no extra flags needed.
# Omit or leave blank to use the default profile.
AWS_PROFILE=myprofile
